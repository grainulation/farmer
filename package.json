{
  "name": "@grainulation/farmer",
  "version": "1.0.2",
  "description": "Mobile-first permission dashboard for AI coding agents",
  "license": "MIT",
  "author": "grainulation contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grainulation/farmer.git"
  },
  "homepage": "https://farmer.grainulation.com",
  "bugs": {
    "url": "https://github.com/grainulation/farmer/issues"
  },
  "keywords": [
    "ai",
    "permissions",
    "dashboard",
    "claude-code",
    "agent",
    "developer-tools",
    "grainulation"
  ],
  "type": "module",
  "main": "./lib/index.js",
  "exports": {
    ".": "./lib/index.js",
